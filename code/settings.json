{
  // Workbench and Editor Settings
  "workbench.colorTheme": "Gruvbox Dark Hard",
  "workbench.productIconTheme": "fluent-icons",
  "workbench.iconTheme": "catppuccin-mocha",
  "workbench.startupEditor": "none",
  "workbench.sideBar.location": "right",
  "workbench.editor.showTabs": "single",
  "workbench.editor.enablePreview": false,
  "breadcrumbs.filePath": "last",
  "workbench.list.smoothScrolling": true,
  "window.menuBarVisibility": "hidden",
  "workbench.layoutControl.enabled": false,
  "window.commandCenter": false,
  "editor.minimap.enabled": false,
  "editor.cursorBlinking": "smooth",
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.lineNumbers": "off",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.overviewRulerBorder": false,
  "editor.linkedEditing": true,
  "editor.lightbulb.enabled": "off",
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit",
    "source.fixAll": "explicit"
  },
  "editor.wordWrap": "on",
  "explorer.sortOrder": "type",
  "editor.tabSize": 2,
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell"
    }
  },
  "files.autoSave": "afterDelay",
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  // Typography
  "editor.fontFamily": "BerkeleyMono Nerd Font Mono",
  "editor.fontWeight": "bold",
  "editor.fontSize": 14,
  "window.zoomLevel": 1,
  "editor.lineHeight": 2,
  "editor.fontLigatures": true,
  "terminal.integrated.fontFamily": "BerkeleyMono Nerd Font Mono",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.lineHeight": 1.5,
  "errorLens.fontFamily": "BerkeleyMono Nerd Font Mono",
  "errorLens.fontSize": "16",
  "errorLens.fontStyleItalic": true,
  "better-comments.tags": [
    {
      "tag": "!",
      "color": "#FF2D00",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "?",
      "color": "#3498DB",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "//",
      "color": "#474747",
      "strikethrough": true,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "todo",
      "color": "#FF8C00",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "*",
      "color": "#98C379",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    }
  ],
  // Programming Languages
  // Javascript
  "[javascript]": {
    "editor.maxTokenizationLineLength": 2500,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // Markdown
  "[markdown]": {
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "editor.unicodeHighlight.invisibleCharacters": false,
    "editor.wordWrap": "on",
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "yzhang.markdown-all-in-one",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    }
  },
  // Rust
  "[rust]": { "editor.defaultFormatter": "rust-lang.rust-analyzer" },
  // Go
  "[go]": {
    "editor.insertSpaces": false,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    },
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.defaultFormatter": "golang.go"
  },
  "[lua]": {
    "editor.quickSuggestions": {
      "comments": "inline",
      "other": "on",
      "strings": "on"
    },
    "editor.semanticHighlighting.enabled": true,
    "editor.defaultFormatter": "sumneko.lua"
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.vscode-pylance",
    "editor.formatOnSave": true,
    "editor.formatOnType": true
  },
  // Color Highlight
  "color-highlight.enable": true,
  "color-highlight.markerType": "background",
  "color-highlight.languages": ["*"],
  "gutterpreview.showImagePreviewOnGutter": true,
  "workbench.activityBar.location": "hidden",
  "security.workspace.trust.banner": "always"
}
